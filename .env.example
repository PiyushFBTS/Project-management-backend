# ============================================================
# IT Project Management System — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Application
NODE_ENV=development
PORT=3001

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_DATABASE=it_project_management
DB_SYNCHRONIZE=false
DB_LOGGING=false

# JWT — Admin (web portal) tokens
JWT_SECRET=change_this_to_a_long_random_admin_secret
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=change_this_to_a_long_random_admin_refresh_secret
JWT_REFRESH_EXPIRY=7d

# JWT — Employee (mobile app) tokens
JWT_EMPLOYEE_SECRET=change_this_to_a_long_random_employee_secret
JWT_EMPLOYEE_EXPIRY=1h
JWT_EMPLOYEE_REFRESH_SECRET=change_this_to_a_long_random_employee_refresh_secret
JWT_EMPLOYEE_REFRESH_EXPIRY=30d

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
